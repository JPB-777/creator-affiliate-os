# ===========================================
# AffiliateOS Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# Database
# --------
# PostgreSQL connection string
# For Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# For local Postgres: postgresql://user:pass@localhost:5432/affiliateos
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Database driver: "neon" or "postgres"
# If not set, auto-detected from DATABASE_URL (neon.tech = neon, otherwise postgres)
# DB_DRIVER=neon

# Authentication (Better Auth)
# ----------------------------
# Generate a secure random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# The canonical URL of your app (used server-side by Better Auth)
BETTER_AUTH_URL=http://localhost:3000

# The public URL of your app (used client-side for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Alerts (Resend)
# ---------------------
# Get a free API key at https://resend.com (3,000 emails/month free)
# Optional: if not set, email alerts are silently disabled
# RESEND_API_KEY=re_xxxxxxxxxxxx

# OAuth Providers (Optional)
# --------------------------
# GitHub: https://github.com/settings/developers → New OAuth App
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# If not set, OAuth buttons are hidden on sign-in/sign-up pages
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cron Security (Vercel)
# ----------------------
# Vercel provides this automatically for cron job authentication
# CRON_SECRET=your-cron-secret
